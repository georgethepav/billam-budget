# Postgres connection string (Vercel Postgres or Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# bcrypt hash of the chosen site password.
# Generate with: npm run hash-password -- 'your-plaintext-password'
SITE_PASSWORD_HASH=

# Random 32+ byte string used to sign the session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
